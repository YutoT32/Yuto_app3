<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>ECサイト-app3</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <header>
      <!-- ナビゲーションリンクをnavタグでグループ化 -->
      <nav class="header-nav" role="navigation" aria-label="global navigation">
        <div class="logo">
          <a href="/">SHOP</a>
        </div>
        <div class="header-search">
          <form action="/search" method="GET">
            <input type="text" name="q" class="search-input" placeholder="商品を検索...">
          </form>
        </div>
        <div class="nav-items">
          <a href="/index">一覧</a>
          <a href="/cart">カート</a>
          <a href="/login">ログイン</a>
        </div>
      </nav>

    </header>
    <div class="container">
      <!-- asideタグでサイドバーを明確化 -->
      <aside class="sidebar" role="complementary" aria-label="category list">
        <h3>カテゴリー </h3>

        <!-- JavascriptのforEachでcategoriesを表示 -->
        <% const categories = [
          {id: 1, name: 'Tシャツ'}, 
          {id: 2, name: 'ワイシャツ'}, 
          {id: 3, name: 'ズボン'}
        ]; %>
        <ul>
          <% categories.forEach((category) => { %>
            <li><%= category.name %></li>
          <% }); %>
        </ul>

      </aside>

      <!-- メインコンテンツ -->
      <main role="main">
        <h2>商品一覧</h2>

        <!-- JavascriptのforEachでProductsを表示 -->
        <div class="products-grid">
          <!-- Productsを表示 -->
          <% Products.forEach((product) => { %>
          <a href="/products/<%= product.productID %>" class="product-card-link">
            <div class="product-card">
              <img src="<%= product.image %>" alt="product image">
              <h3><%= product.productName %></h3>
              <p class="product-card-price">¥<%= product.unitPrice.toLocaleString() %></p>
            </div>
          </a>
          <% }); %>
        </div>

      </main>
    </div>

    <footer>
      <p>&copy; 2025 Yuto Takahashi All Rights Reserved.</p>
    </footer>
  </body>
</html>
<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>ECサイト-app3</title>
    <!-- publicディレクトリ起点で、外部CSSファイルを指定 -->
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <header>
      <!-- 上段：ロゴ・検索・カート/ログイン -->
      <nav class="header-nav" role="navigation" aria-label="global navigation">
        <div class="logo">
          <a href="/">SHOP</a>
        </div>
        <!-- 検索バー -->
        <div class="header-search">
          <input type="text" class="search-input" placeholder="商品を検索...">
        </div>
        <!-- カート・ログインリンク -->
        <div class="nav-items">
          <a href="/cart">カート</a>
          <a href="/login">ログイン</a>
        </div>
      </nav>

      <!-- 下段：カテゴリーナビゲーションバー -->
      <nav class="category-nav" role="navigation" aria-label="category navigation">
        <ul>
          <li><a href="/index">すべて</a></li>
          <li><a href="#">トップス</a></li>
          <li><a href="#">パンツ</a></li>
          <li><a href="#">セール</a></li>
        </ul>
      </nav>
    </header>

    <div class="container">
      <!-- asideタグでサイドバーを明確化 -->
      <aside class="sidebar" role="complementary" aria-label="category list">
        <h3>カテゴリー </h3>

        <!-- JavascriptのforEachでcategoriesを表示 -->
        <% const categories = [
          {id: 1, name: 'Tシャツ'}, 
          {id: 2, name: 'ワイシャツ'}, 
          {id: 3, name: 'ズボン'}
        ]; %>
        <ul>
          <% categories.forEach((category) => { %>
            <li><%= category.name %></li>
          <% }); %>
        </ul>

      </aside>

      <!-- メインコンテンツ -->
      <main role="main">
        <h2>おすすめ商品</h2>

        <!-- JavascriptのforEachでrecommendedProductsを表示 -->
        <!--
        <% const recommendedProducts = [
          {id: 1, name: 'Tシャツ', image: '/images/tops/Tシャツ.jpg'}, 
          {id: 2, name: 'ズボン', image: '/images/pants/ズボン.jpg'}, 
          {id: 3, name: 'セーター', image: '/images/sweaters/セーター.jpg'}, 
          {id: 4, name: 'ワイシャツ', image: '/images/shirts/ワイシャツ.jpg'}
        ]; %>
        -->
        <div class="products-grid">
          <!-- 商品表示-->
          <% recommendedProducts.forEach((product) => { %>
          <div class="product-card">
            <img src="<%= product.image %>">
            <h3><%= product.name %></h3>
          </div>
          <% }); %>
        </div>

      </main>
    </div>

    <footer>
      <p>&copy; 2025 Yuto Takahashi All Rights Reserved.</p>
    </footer>
  </body>
</html>
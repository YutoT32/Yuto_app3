<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>ECサイト-app3</title>
    <!-- publicディレクトリ起点で、外部CSSファイルを指定 -->
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <header class="transparent">
      <!-- 上段：ロゴ・検索・カート/ログイン -->
      <nav class="header-nav" role="navigation" aria-label="global navigation">
        <div class="logo">
          <a href="/">SHOP</a>
        </div>
        <!-- 検索バー -->
        <div class="header-search">
          <input type="text" class="search-input" placeholder="商品を検索...">
        </div>
        <!-- カート・ログインリンク -->
        <div class="nav-items">
          <a href="/cart">カート</a>
          <a href="/login">ログイン</a>
        </div>
      </nav>

      <!-- 下段：カテゴリーナビゲーションバー -->
      <nav class="category-nav" role="navigation" aria-label="category navigation">
        <ul>
          <li><a href="/index">すべて</a></li>
          <li><a href="#">トップス</a></li>
          <li><a href="#">パンツ</a></li>
          <li><a href="#">セール</a></li>
        </ul>
      </nav>
    </header>

    <!-- ヒーローバナー：ページ幅いっぱいに表示 -->
    <section class="hero">
      <div class="hero-content">
        <p class="hero-sub">新作コレクション</p>
        <h1 class="hero-title">シンプルで、長く使える。</h1>
        <a href="/index" class="hero-btn">商品を見る</a>
      </div>
    </section>

    <div class="container">
      <!-- メインコンテンツ -->
      <main role="main">
        <h2>おすすめ商品</h2>

        <!-- JavascriptのforEachでrecommendedProductsを表示 -->
        <div class="products-grid">
          <!-- 商品表示-->
          <% recommendedProducts.forEach((product) => { %>
          <a href="/products/<%= product.productID %>" class="product-card-link">
            <div class="product-card">
              <img src="<%= product.image %>">
              <h3><%= product.productName %></h3>
              <p class="product-card-price">¥<%= product.unitPrice.toLocaleString() %></p>
            </div>
          </a>
          <% }); %>
        </div>

      </main>
    </div>

    <footer>
      <p>&copy; 2025 Yuto Takahashi All Rights Reserved.</p>
    </footer>
  </body>
</html>